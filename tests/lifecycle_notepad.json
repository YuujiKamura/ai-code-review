{
  "exe": "C:/Windows/System32/notepad.exe",
  "steps": [
    { "action": "wait", "seconds": 3 },
    { "action": "screenshot", "expect": "メモ帳（Notepad）のウィンドウが開いている。テキスト入力エリアが見える" },
